# 用于获取金融数据
# 从 https://financialdatasets.ai/ 获取 Financial Datasets API 密钥
FINANCIAL_DATASETS_API_KEY=your-financial-datasets-api-key

# 数据源选择："akshare" 用于 A 股分析，"financial_datasets" 用于美股分析
DATA_SOURCE=akshare

# 用于运行 OpenAI 托管的 LLM（GPT 5 等）
# 从 https://platform.openai.com/ 获取 OpenAI API 密钥
OPENAI_API_KEY=your-openai-api-key

# 用于运行 Anthropic 托管的 LLM（claude-4-sonnet、claude-4.1-opus 等）
# 从 https://anthropic.com/ 获取 Anthropic API 密钥
ANTHROPIC_API_KEY=your-anthropic-api-key

# 用于运行 DeepSeek 托管的 LLM（deepseek-chat、deepseek-reasoner 等）
# 从 https://deepseek.com/ 获取 DeepSeek API 密钥
DEEPSEEK_API_KEY=your-deepseek-api-key

# 用于运行 Groq 托管的 LLM（deepseek、llama3 等）
# 从 https://groq.com/ 获取 Groq API 密钥
GROQ_API_KEY=your-groq-api-key

# 用于运行 Gemini 托管的 LLM（gemini-2.5-flash、gemini-2.5-pro）
# 从 https://ai.dev/ 获取 Google API 密钥
GOOGLE_API_KEY=your-google-api-key

# 用于运行 xAI 托管的 LLM（Grok 4 等）
XAI_API_KEY=your-xai-api-key

# 用于运行 GigaChat LLM
GIGACHAT_API_KEY=your-gigachat-api-key

# 用于运行 OpenRouter 托管的 LLM
OPENROUTER_API_KEY=your-openrouter-api-key

# 用于运行 Microsoft Azure OpenAI 托管的 LLM（gpt-4o、gpt-4o-mini 等）
# 从 https://oai.azure.com/ 获取 Azure OpenAI 设置
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=your-azure-openai-endpoint
AZURE_OPENAI_DEPLOYMENT_NAME=your-azure-openai-deployment-name
